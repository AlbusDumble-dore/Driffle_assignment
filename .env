Subscription name = replication slot name
Cloud SQL restricts certain slot names (cloudsql_*)
Cloud SQL Auth Proxy removes need for SSL config

Volume loss requires:
  dropping remote slot
  recreating subscription


# Local PostgreSQL subscriber (inside Docker)
POSTGRES_USER=localadmin
POSTGRES_PASSWORD=localpass
POSTGRES_DB=replica_db
PG_LOCAL_PORT=5433

# Cloud SQL primary (publisher)
PUB_HOST=127.0.0.1
PUB_PORT=5432
PUB_USER=repl_user
PUB_PASSWORD=Admin@1234Replication
PUB_DB=postgres
PUB_PUBLICATION=cloud_pub

# Subscriber / slot name
SUB_NAME=local_sub_01

# Cloud SQL proxy connection mode
PGSSLMODE=disable
